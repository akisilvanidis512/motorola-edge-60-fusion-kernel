name: Build Streamer and GUI Wrapper

on:
  push:
    branches: [ "master", "main" ]
  pull_request:
    branches: [ "master", "main" ]
  workflow_dispatch:

jobs:
  build-windows:
    runs-on: windows-latest

    steps:
    - name: Checkout Repository
      uses: actions/checkout@v4

    - name: Setup MSYS2 and Install Dependencies
      uses: msys2/setup-msys2@v2
      with:
        msystem: MINGW64
        update: true
        install: >-
          mingw-w64-x86_64-toolchain
          mingw-w64-x86_64-cmake
          mingw-w64-x86_64-libusb
          mingw-w64-x86_64-rtl-sdr
          mingw-w64-x86_64-libev

    - name: Build rtl_fm_streamer (Base CLI)
      shell: msys2 {0}
      run: |
        mkdir build
        cd build
        cmake -G "MinGW Makefiles" ..
        cmake --build .

    - name: Create and Compile C# GUI Wrapper
      shell: pwsh
      run: |
        $guiCode = @"
        using System;
        using System.Diagnostics;
        using System.Windows.Forms;
        using System.Drawing;

        class App : Form {
            TextBox freqInput;
            ComboBox modeSelect;
            Button startBtn;
            Process streamer;

            public App() {
                Text = "RTL FM Streamer";
                Size = new Size(320, 200);
                FormBorderStyle = FormBorderStyle.FixedDialog;
                StartPosition = FormStartPosition.CenterScreen;
                MaximizeBox = false;

                Label l1 = new Label() { Text = "Frequency (MHz):", Top = 20, Left = 20, Width = 100 };
                freqInput = new TextBox() { Text = "93.2", Top = 20, Left = 120, Width = 140 };

                Label l2 = new Label() { Text = "Mode:", Top = 60, Left = 20, Width = 100 };
                modeSelect = new ComboBox() { Top = 60, Left = 120, Width = 140, DropDownStyle = ComboBoxStyle.DropDownList };
                modeSelect.Items.AddRange(new string[] { "Mono (0)", "Stereo (1)" });
                modeSelect.SelectedIndex = 1; // Default to Stereo

                startBtn = new Button() { Text = "Launch Streamer", Top = 100, Left = 20, Width = 240, Height = 35 };
                startBtn.Click += Start_Click;

                Controls.Add(l1); Controls.Add(freqInput);
                Controls.Add(l2); Controls.Add(modeSelect);
                Controls.Add(startBtn);
                
                FormClosing += (s,e) => { if(streamer != null && !streamer.HasExited) streamer.Kill(); };
            }

            void Start_Click(object sender, EventArgs e) {
                if(streamer != null && !streamer.HasExited) {
                    streamer.Kill();
                    startBtn.Text = "Launch Streamer";
                    return;
                }
                
                try {
                    streamer = new Process();
                    streamer.StartInfo.FileName = "rtl_fm_streamer.exe";
                    streamer.StartInfo.Arguments = "-P 2346"; // Default Port
                    streamer.StartInfo.UseShellExecute = true;
                    streamer.Start();
                    
                    // Format frequency for URL (e.g., 93.2 -> 93200000)
                    string freqStr = freqInput.Text.Replace(".", "").Replace(",", "");
                    if(freqStr.Length < 8) freqStr = freqStr.PadRight(8, '0');
                    
                    // 0 for Mono, 1 for Stereo
                    string mode = modeSelect.SelectedIndex == 0 ? "0" : "1";
                    string url = $"http://localhost:2346/{freqStr}/{mode}";
                    
                    MessageBox.Show($"Streamer is running!\n\n1. Open VLC Media Player\n2. Press Ctrl+N (Open Network Stream)\n3. Enter this URL:\n\n{url}", "Success", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    startBtn.Text = "Stop Streamer";
                } catch (Exception ex) {
                    MessageBox.Show("Error starting rtl_fm_streamer.exe.\n" + ex.Message, "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
                }
            }

            static void Main() {
                Application.EnableVisualStyles();
                Application.Run(new App());
            }
        }
        "@
        Set-Content -Path GuiWrapper.cs -Value $guiCode
        # Compile using the built-in Windows C# compiler
        & "C:\Windows\Microsoft.NET\Framework64\v4.0.30319\csc.exe" /target:winexe /out:build\RTL_Streamer_GUI.exe GuiWrapper.cs

    - name: Package Release Files
      shell: msys2 {0}
      run: |
        mkdir release_package
        
        # Copy both executables
        cp build/rtl_fm_streamer.exe release_package/
        cp build/RTL_Streamer_GUI.exe release_package/
        
        # Copy MSYS2 runtime dependencies
        cp /mingw64/bin/librtlsdr.dll release_package/ || true
        cp /mingw64/bin/libusb-1.0.dll release_package/ || true
        cp /mingw64/bin/libwinpthread-1.dll release_package/ || true
        cp /mingw64/bin/libgcc_s_seh-1.dll release_package/ || true
        cp /mingw64/bin/libstdc++-6.dll release_package/ || true

    - name: Upload Artifact
      uses: actions/upload-artifact@v4
      with:
        name: rtl_fm_streamer-GUI-Windows-x64
        path: release_package/
